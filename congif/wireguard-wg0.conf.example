# =============================================================================
# wg0.conf.example — WireGuard VPN Configuration Template
#
# Copy to: /etc/wireguard/wg0.conf
# Permissions: sudo chmod 600 /etc/wireguard/wg0.conf
#
# Generate keys:
#   sudo mkdir -p /etc/wireguard/keys
#   sudo sh -c 'umask 077; wg genkey | tee /etc/wireguard/keys/server.private \
#     | wg pubkey > /etc/wireguard/keys/server.public'
#
# Start:   sudo wg-quick up wg0
# Stop:    sudo wg-quick down wg0
# Enable:  sudo systemctl enable wg-quick@wg0
# Status:  sudo wg show wg0
# =============================================================================

[Interface]
# This server's private key — never share this
PrivateKey = <YOUR_SERVER_PRIVATE_KEY>

# IP address of this server on the VPN network
Address = 10.10.30.1/24

# WireGuard listens on this UDP port
ListenPort = 51820

# NAT: forward VPN traffic out through your wireless interface
# Replace wlp2s0 with your actual interface name (check: ip link show)
PostUp   = iptables -A FORWARD -i wg0 -j ACCEPT; \
           iptables -t nat -A POSTROUTING -o wlp2s0 -j MASQUERADE
PostDown = iptables -D FORWARD -i wg0 -j ACCEPT; \
           iptables -t nat -D POSTROUTING -o wlp2s0 -j MASQUERADE

# =============================================================================
# [Peer] — Add one block per client that connects to this server
# =============================================================================

[Peer]
# Client's public key (generated on the client device)
PublicKey = <CLIENT_PUBLIC_KEY>

# IP address assigned to this client inside the VPN
AllowedIPs = 10.10.30.2/32

# Optional: uncomment to keep NAT alive (useful for mobile clients)
# PersistentKeepalive = 25
